# ---------------------------------------------------------------------------
# Webhook
# ---------------------------------------------------------------------------
WEBHOOK_ADDR=:8080
# WEBHOOK_SECRET is the Meta App Secret — validates the X-Hub-Signature-256 HMAC.
WEBHOOK_SECRET=local-secret
# WEBHOOK_VERIFY_TOKEN is the GET-handshake token you also set in the Meta dashboard.
WEBHOOK_VERIFY_TOKEN=local-secret
META_GRAPH_API_TOKEN=something
WHATSAPP_PHONE_NUMBER_ID=something

# ---------------------------------------------------------------------------
# Dashboard API
# ---------------------------------------------------------------------------
API_ADDR=:8081

# Demo user credentials (fed into cognito-init — docker compose / make demo)
USER_DEMO_PASSWORD=fake123

# COGNITO_JWKS_URL/COGNITO_ISSUER/COGNITO_CLIENT_ID are not listed here: under
# docker compose they're derived at container startup from the pool/client
# cognito-init creates (see docker/dashboard-api/entrypoint.sh), since
# cognito-local generates those IDs dynamically and they can't be pinned.
# For a bare `go run ./apps/dashboard-api/cmd/local`, run cognito-init once
# and export the three vars yourself.

# ---------------------------------------------------------------------------
# Gemini (WhatsApp message parsing)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=https://something

# ---------------------------------------------------------------------------
# DynamoDB Local (injected by docker compose — not needed for native Go run)
# ---------------------------------------------------------------------------
DYNAMODB_ENDPOINT=http://localhost:8000
FINANCIAL_ENTRIES_TABLE=emerbot-local-financial-entries

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8081
VITE_COGNITO_ENDPOINT=http://localhost:9229
# VITE_COGNITO_CLIENT_ID is derived at container startup by docker/web/entrypoint.sh
# (see COGNITO_* note above) — not set here.
