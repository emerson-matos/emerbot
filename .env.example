# ---------------------------------------------------------------------------
# Webhook
# ---------------------------------------------------------------------------
WEBHOOK_ADDR=:8080
# WEBHOOK_SECRET is the Meta App Secret — validates the X-Hub-Signature-256 HMAC.
WEBHOOK_SECRET=local-secret
# WEBHOOK_VERIFY_TOKEN is the GET-handshake token you also set in the Meta dashboard.
WEBHOOK_VERIFY_TOKEN=local-secret

# ---------------------------------------------------------------------------
# Dashboard API
# ---------------------------------------------------------------------------
API_ADDR=:8081
JWT_SECRET=local-jwt-secret-change-in-prod

# Demo user credentials (docker compose / make run-api)
USER_DEMO_PASSWORD=fake123

# ---------------------------------------------------------------------------
# Gemini (WhatsApp message parsing)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# DynamoDB Local (injected by docker compose — not needed for native Go run)
# ---------------------------------------------------------------------------
DYNAMODB_ENDPOINT=http://localhost:8000
FINANCIAL_ENTRIES_TABLE=emerbot-local-financial-entries
USERS_TABLE=emerbot-local-users
REFRESH_TOKENS_TABLE=emerbot-local-refresh-tokens

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8081
