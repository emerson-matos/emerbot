# ---------------------------------------------------------------------------
# Webhook
# ---------------------------------------------------------------------------
WEBHOOK_ADDR=:8080
WEBHOOK_SECRET=local-secret

# ---------------------------------------------------------------------------
# Dashboard API
# ---------------------------------------------------------------------------
API_ADDR=:8081
JWT_SECRET=local-jwt-secret-change-in-prod

# User credentials for local seeding (docker compose / make run-api)
USER_EMERSON_EMAIL=emerson@farmacia.local
USER_EMERSON_PASSWORD=senha123
USER_PAI_EMAIL=pai@farmacia.local
USER_PAI_PASSWORD=senha123

# ---------------------------------------------------------------------------
# Gemini (WhatsApp message parsing)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ---------------------------------------------------------------------------
# DynamoDB Local (injected by docker compose — not needed for native Go run)
# ---------------------------------------------------------------------------
DYNAMODB_ENDPOINT=http://localhost:8000
MESSAGES_TABLE=emerbot-local-messages
MEMORIES_TABLE=emerbot-local-memories
FINANCIAL_ENTRIES_TABLE=emerbot-local-financial-entries
USERS_TABLE=emerbot-local-users
REFRESH_TOKENS_TABLE=emerbot-local-refresh-tokens

# ---------------------------------------------------------------------------
# AWS (local fake credentials for DynamoDB Local)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8081
